		{"id":"f4f5e0f83062f83d","type":"text","text":"$u_{norm}=\\frac{u}{W}, v_{norm}=\\frac{v}{H}$\n$\\hspace{0.9cm}(u_{norm},v_{norm})$","x":15,"y":259,"width":195,"height":71,"color":"4"},
		{"id":"de4102f85256c0be","type":"text","text":"$u\\in[-\\frac{W}{2},....,\\frac{H}{2}-1]$\n$v\\in [-\\frac{H}{2},....,\\frac{W}{2}-1]$","x":113,"y":140,"width":192,"height":75,"color":"6"},
