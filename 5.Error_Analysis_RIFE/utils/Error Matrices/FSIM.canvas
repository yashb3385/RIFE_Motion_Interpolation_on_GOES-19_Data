		{"id":"fba110a98b23d1a9","type":"text","text":"$\\huge{s(x,y)=\\frac{1}{N}\\Big(\\frac{\\sum\\limits_nA_{n,o}(x,y)}{A_{max.,o}(x,y)+\\epsilon}\\Big)}$ ","x":-493,"y":1286,"width":295,"height":96,"color":"5"},
