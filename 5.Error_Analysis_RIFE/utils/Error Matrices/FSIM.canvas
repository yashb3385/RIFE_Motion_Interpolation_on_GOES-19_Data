		{"id":"5289fff64ee20cba","type":"text","text":"$\\huge{S_{GM}(X)=\\frac{2.GM_1(X).GM_2(X)+T_2}{GM_1^2(X)+GM_2^2(X)+T_2}}$ ","x":-1097,"y":1636,"width":324,"height":80,"color":"#6600ff"},
