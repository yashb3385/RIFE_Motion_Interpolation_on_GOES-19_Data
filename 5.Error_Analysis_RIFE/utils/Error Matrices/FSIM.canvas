		{"id":"a2278c49e9dd0a37","type":"text","text":"$\\omega=\\sqrt{u_{norm}^2+v_{norm}^2}$\n$\\theta=atan2(u_{norm},v_{norm})$ $$(\\omega,\\theta)$$","x":-64,"y":393,"width":192,"height":112,"color":"4"},
		{"id":"bc23571fef54e85d","type":"text","text":"$\\huge{G_{n,o}(\\omega,\\theta)=e^{\\frac{-(\\ln(\\frac{\\omega}{\\omega_n}))^2}{2(\\ln(\\frac{\\sigma_f}{\\omega_n}))^2}}.e^{\\frac{-(\\theta-\\theta_o)^2}{2\\sigma_{\\theta}^2}}}$","x":-30,"y":811,"width":335,"height":105,"color":"5"},
		{"id":"23232049ef75649f","type":"text","text":"$\\omega_n=\\omega_{max.}\\delta^n$ ","x":130,"y":594,"width":125,"height":60,"color":"5"},
		{"id":"7e839c97feb0c84e","type":"text","text":"$\\sigma_f=0.55\\omega_n$ ","x":2,"y":692,"width":123,"height":60,"color":"1"},
