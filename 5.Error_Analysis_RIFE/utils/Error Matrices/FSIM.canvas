		{"id":"6746c32e05be3938","type":"text","text":"$F(u,v)=\\sum\\limits_{x=0}^{W-1}\\sum\\limits_{y=0}^{H-1}I_i(x,y)e^{-j2\\pi (\\frac{u.x}{W}+\\frac{v.y}{H})}$","x":-148,"y":30,"width":288,"height":70,"color":"5"},
