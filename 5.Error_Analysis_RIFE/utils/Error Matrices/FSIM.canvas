		{"id":"df0f66bee6878020","type":"text","text":"$E_{even}(x,y)=\\sum\\limits_{n}e_{n,o}(x,y)$\n$O_{odd}(x,y)=\\sum\\limits_no_{n,o}(x,y)$ ","x":283,"y":1078,"width":268,"height":98,"color":"4"},
